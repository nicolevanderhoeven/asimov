# Copy this to .env and fill in your actual credentials.

# --- LLM provider keys ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
OPENAI_API_KEY=sk-proj-your_openai_key_here

# --- OpenTelemetry (metrics + traces to Grafana Cloud) ---
# The Sigil SDK's gen_ai.* histograms and spans are exported through these.
OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
# Base64-encoded "<instance_id>:<otlp_write_token>". No "Basic " prefix — the app adds it.
OTLP_HEADERS=base64_instance_colon_token_here

# --- Grafana Sigil SDK (generations / conversations) ---
# Leave GRAFANA_CLOUD_SIGIL_ENDPOINT unset to disable Sigil (OTel still works).
GRAFANA_CLOUD_SIGIL_ENDPOINT=https://sigil-prod-us-central-0.grafana.net/api/v1/generations:export
GRAFANA_CLOUD_INSTANCE_ID=your_instance_id_here
GRAFANA_CLOUD_API_KEY=your_sigil_write_api_key_here

# --- Optional ---
# Explicit agent version. Unset = "git-<short-sha>" falling back to "1.0.0".
# ASIMOV_AGENT_VERSION=v1.2.3

# Path to your CA bundle if Python can't find one (common on python.org macOS builds).
# SSL_CERT_FILE=/path/to/certifi/cacert.pem

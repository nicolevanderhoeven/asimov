# OpenTelemetry Configuration
# Copy this to .env and fill in your actual Grafana Cloud credentials

# Grafana Cloud OTLP credentials
GRAFANA_CLOUD_USERNAME=your_username_here
GRAFANA_CLOUD_PASSWORD=your_password_here
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-3.grafana.net/otlp

# OpenLIT configuration (used by your Python app)
OTLP_ENDPOINT=http://localhost:4318
OTLP_HEADERS=your_auth_headers_here

